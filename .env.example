APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URLS=http://host.docker.internal:11434,http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_NUM_BATCH=1
REQUIRED_DEMO_MODEL=localscript-qwen25coder7b
DEFAULT_MODEL=localscript-qwen25coder7b
OPTIONAL_BENCHMARK_MODELS=
STRICT_MODELS=
LUAC_BINARY=luac5.4
LUACHECK_BINARY=.tools/luacheck/luacheck.exe
STYLUA_BINARY=.tools/stylua/stylua.exe
SYNTAX_REQUIRE_LUAC=false
GENERATION_CANDIDATE_COUNT=3
REPAIR_MAX_PASSES=1
KB_DIR=app/kb
REPORTS_DIR=app/reports
