{"id": "aug_last_email_en", "prompt": "Get the last email from wf.vars.emails without JsonPath.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"emails": ["user1@example.com", "user2@example.com", "user3@example.com"]}}}, "expected_runtime_output": "user3@example.com", "expected_contains": ["wf.vars.emails"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_counter_ru", "prompt": "Инкрементируй счетчик wf.vars.try_count_n на единицу.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"try_count_n": 3}}}, "expected_runtime_output": 4, "expected_contains": ["wf.vars.try_count_n", "+ 1"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_cleanup_en", "prompt": "Keep only ID, ENTITY_ID and CALL fields in wf.vars.RESTbody.result records.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"RESTbody": {"result": [{"ID": 123, "ENTITY_ID": 456, "CALL": "call_1", "EXTRA": "x"}, {"ID": 789, "ENTITY_ID": 101, "CALL": "call_2", "OTHER": "y"}]}}}}, "expected_runtime_output": [{"ID": 123, "ENTITY_ID": 456, "CALL": "call_1"}, {"ID": 789, "ENTITY_ID": 101, "CALL": "call_2"}], "expected_contains": ["wf.vars.RESTbody.result", "ID", "ENTITY_ID", "CALL"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_iso_ru", "prompt": "Собери ISO-строку времени из wf.vars.json.IDOC.ZCDF_HEAD.DATUM и TIME.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"json": {"IDOC": {"ZCDF_HEAD": {"DATUM": "20231015", "TIME": "153000"}}}}}}, "expected_runtime_output": "2023-10-15T15:30:00.00000Z", "expected_contains": ["wf.vars.json.IDOC.ZCDF_HEAD.DATUM", "string.format"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_array_norm_en", "prompt": "Normalize package items to arrays in wf.vars.json.IDOC.ZCDF_HEAD.ZCDF_PACKAGES.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"json": {"IDOC": {"ZCDF_HEAD": {"ZCDF_PACKAGES": [{"items": [{"sku": "A"}, {"sku": "B"}]}, {"items": {"sku": "C"}}]}}}}}}, "expected_runtime_output": [{"items": [{"sku": "A"}, {"sku": "B"}]}, {"items": [{"sku": "C"}]}], "expected_contains": ["wf.vars.json.IDOC.ZCDF_HEAD.ZCDF_PACKAGES", "ensureArray"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_filter_ru", "prompt": "Оставь в parsedCsv только записи с непустым Discount или Markdown.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"vars": {"parsedCsv": [{"SKU": "A001", "Discount": "10%", "Markdown": ""}, {"SKU": "A002", "Discount": "", "Markdown": "5%"}, {"SKU": "A003", "Discount": null, "Markdown": null}, {"SKU": "A004", "Discount": "", "Markdown": ""}]}}}, "expected_runtime_output": [{"SKU": "A001", "Discount": "10%", "Markdown": ""}, {"SKU": "A002", "Discount": "", "Markdown": "5%"}], "expected_contains": ["parsedCsv", "Discount", "Markdown"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_square_ru", "prompt": "Верни JSON с num и squared, где squared это квадрат числа.", "expected_mode": "json_with_lua_wrappers", "wf_fixture": {"wf": {"initVariables": {"number": "5", "num": "5"}}}, "expected_runtime_output": {"num": 5, "squared": 25}, "expected_contains": ["squared", "tonumber"], "expected_not_contains": ["$.", "jsonpath"]}
{"id": "aug_unix_en", "prompt": "Convert wf.initVariables.recallTime ISO string into unix timestamp in Lua.", "expected_mode": "raw_lua", "wf_fixture": {"wf": {"initVariables": {"recallTime": "2023-10-15T15:30:00+00:00"}}}, "expected_runtime_output": 1697383800, "expected_contains": ["wf.initVariables.recallTime", "return"], "expected_not_contains": ["$.", "jsonpath"]}
